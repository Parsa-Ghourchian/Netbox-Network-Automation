# ============================================================
# Generated by NetBox-driven Network Automation Lab
# Device: {{ device.name }}
# Platform: {{ device.platform }}
# Site: {{ device.site }}
# WARNING: Review before applying to any production device.
# ============================================================

/system identity set name="{{ device.name }}"

{% for interface in interfaces %}
# Interface: {{ interface.name }}
/interface ethernet set [ find default-name={{ interface.name }} ] comment="{{ interface.description | default('Managed by NetBox', true) }}"
{% endfor %}

{% for interface in interfaces %}
{% for ip in interface.ip_addresses %}
{% if ip.is_ipv4 %}
# IP address for {{ interface.name }}
# Remove only NetBox-managed IP address for this device/interface before re-adding it.
/ip address remove [ find comment="NetBox: {{ device.name }} {{ interface.name }}" ]
/ip address add address={{ ip.address }} interface={{ interface.name }} comment="NetBox: {{ device.name }} {{ interface.name }}"
{% endif %}
{% endfor %}
{% endfor %}

# End of generated RouterOS configuration
