# ============================================================
# Generated by NetBox-driven Network Automation Lab
# Device: {{ device.name }}
# Platform: {{ device.platform }}
# Site: {{ device.site }}
# WARNING: Review before applying to any production host.
# ============================================================

network:
  version: 2
  renderer: networkd
  ethernets:
{% for interface in interfaces %}
    {{ interface.name }}:
      dhcp4: false
{% if interface.ip_addresses %}
      addresses:
{% for ip in interface.ip_addresses %}
{% if ip.is_ipv4 %}
        - {{ ip.address }}
{% endif %}
{% endfor %}
{% else %}
      optional: true
{% endif %}
{% endfor %}
